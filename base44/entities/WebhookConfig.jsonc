{
  "name": "WebhookConfig",
  "type": "object",
  "properties": {
    "api_key_id": {
      "type": "string",
      "description": "ID of the ApiKey"
    },
    "callback_url": {
      "type": "string",
      "description": "URL to send webhook notifications"
    },
    "is_active": {
      "type": "boolean",
      "description": "Whether this webhook is active"
    },
    "secret_token": {
      "type": "string",
      "description": "Secret for HMAC signature verification"
    }
  }
}